@using Microsoft.AspNetCore.Components.Authorization
@using BillingSys.Client.Services
@inject GoogleAuthService Auth
@inject NavigationManager Navigation

<AuthorizeView>
    <Authorized>
        <div class="d-flex align-items-center @WrapperClass">
            <span class="@NameClass me-3 text-truncate" style="max-width:14rem;">@context.User.Identity?.Name</span>
            <button type="button" class="@SignOutButtonClass" @onclick="BeginLogOutAsync">
                Sign Out
            </button>
        </div>
    </Authorized>
    <NotAuthorized>
        <button type="button" class="@SignInButtonClass" @onclick="BeginSignInAsync">Sign In</button>
    </NotAuthorized>
</AuthorizeView>

@code {
    #region Parameters

    [Parameter]
    public bool OnDarkBackground { get; set; }

    #endregion

    #region Private Methods

    private string WrapperClass => OnDarkBackground ? "" : "login-shell-light";

    private string NameClass => OnDarkBackground ? "text-light" : "text-body";

    private string SignOutButtonClass => OnDarkBackground
        ? "btn btn-outline-light btn-sm"
        : "btn btn-outline-primary btn-sm";

    private string SignInButtonClass => OnDarkBackground
        ? "btn btn-outline-light btn-sm"
        : "btn btn-outline-primary btn-sm";

    #endregion

    #region Event Handlers

    private async Task BeginSignInAsync()
    {
        await Auth.SignInAsync();
    }

    private async Task BeginLogOutAsync()
    {
        await Auth.SignOutAsync();
        Navigation.NavigateTo("", forceLoad: false);
    }

    #endregion
}
