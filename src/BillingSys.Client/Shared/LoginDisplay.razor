@using Microsoft.AspNetCore.Components.Authorization
@using BillingSys.Client.Services
@inject GoogleAuthService Auth
@inject NavigationManager Navigation

<AuthorizeView>
    <Authorized>
        <div class="d-flex align-items-center">
            <span class="text-light me-3">@context.User.Identity?.Name</span>
            <button type="button" class="btn btn-outline-light btn-sm" @onclick="BeginLogOutAsync">
                Sign Out
            </button>
        </div>
    </Authorized>
    <NotAuthorized>
        <button type="button" class="btn btn-outline-light btn-sm" @onclick="BeginSignInAsync">Sign In</button>
    </NotAuthorized>
</AuthorizeView>

@code {
    #region Event Handlers

    private async Task BeginSignInAsync()
    {
        await Auth.SignInAsync();
    }

    private async Task BeginLogOutAsync()
    {
        await Auth.SignOutAsync();
        Navigation.NavigateTo("", forceLoad: false);
    }

    #endregion
}
