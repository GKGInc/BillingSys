@* Wrigley mascot — PNG (wide art: dog + wordmark); full vs compact via CSS *@

<img src="images/wrigley-logo.png"
     alt="Wrigley mascot"
     class="@_variantClass @CssClass" />

@code {
    #region Parameters

    [Parameter]
    public WrigleyLogoVariant Variant { get; set; } = WrigleyLogoVariant.Full;

    [Parameter]
    public string? CssClass { get; set; }

    #endregion

    #region Private Methods

    private string _variantClass => Variant == WrigleyLogoVariant.Full
        ? "wrigley-logo-img wrigley-logo-full"
        : "wrigley-logo-img wrigley-logo-compact";

    #endregion
}
