@* Transparent PNG mascot — styles in WrigleyLogo.razor.css (NavMenu scoped CSS does not apply to this img). *@

<div class="@_shellClass @CssClass">
    <img src="images/wrigley-logo.png"
         alt=""
         class="wrigley-logo-img"
         loading="lazy"
         decoding="async" />
</div>

@code {
    #region Parameters

    [Parameter]
    public WrigleyLogoVariant Variant { get; set; } = WrigleyLogoVariant.Full;

    [Parameter]
    public string? CssClass { get; set; }

    #endregion

    #region Private Methods

    private string _shellClass => Variant == WrigleyLogoVariant.Full
        ? "wrigley-logo-shell wrigley-logo-shell-full"
        : "wrigley-logo-shell wrigley-logo-shell-compact";

    #endregion
}
