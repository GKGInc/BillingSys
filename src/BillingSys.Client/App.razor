@*
  Authorizing: full-viewport spinner until Google GIS + GoogleAuthenticationStateProvider resolve the user.
  NotAuthorized: unauthenticated users -> RedirectToLogin; authenticated but forbidden -> alert.
*@
@using BillingSys.Client.Services
@using Microsoft.AspNetCore.Components.Web
@inject GoogleAuthService GoogleAuth

<CascadingAuthenticationState>
    <ErrorBoundary>
        <ChildContent>
            <Router AppAssembly="@typeof(App).Assembly">
                <Found Context="routeData">
                    <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                        <NotAuthorized>
                            @if (context.User.Identity?.IsAuthenticated != true)
                            {
                                <RedirectToLogin />
                            }
                            else
                            {
                                <p role="alert">You are not authorized to access this resource.</p>
                            }
                        </NotAuthorized>
                        <Authorizing>
                            <div class="d-flex justify-content-center align-items-center" style="height: 100vh;">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                            </div>
                        </Authorizing>
                    </AuthorizeRouteView>
                    <FocusOnNavigate RouteData="@routeData" Selector="h1" />
                </Found>
                <NotFound>
                    <PageTitle>Not found</PageTitle>
                    <LayoutView Layout="@typeof(MainLayout)">
                        <p role="alert">Sorry, there's nothing at this address.</p>
                    </LayoutView>
                </NotFound>
            </Router>
        </ChildContent>
        <ErrorContent>
            <div class="container py-5 text-center">
                <h1 class="h5 mb-3">Something went wrong</h1>
                <p class="text-muted mb-3">An unexpected error occurred in the app. You can try reloading the page.</p>
                <a href="" class="btn btn-primary">Reload</a>
            </div>
        </ErrorContent>
    </ErrorBoundary>
</CascadingAuthenticationState>

@code {
    #region Lifecycle

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await GoogleAuth.InitializeAsync();

            // Valid token in memory after GIS init → refresh ClaimsPrincipal without calling SignInAsync (avoids One Tap / modal).
            if (await GoogleAuth.IsAuthenticatedAsync())
            {
                GoogleAuth.NotifyAuthenticationStateChanged();
            }
        }
    }

    #endregion
}
