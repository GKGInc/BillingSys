@page "/reports"
@using BillingSys.Client.Services
@using BillingSys.Shared.DTOs
@inject ApiService Api

<PageTitle>Reports</PageTitle>

<h1>Reports</h1>

<div class="row">
    <div class="col-md-6">
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">Weekly Hours Summary</h5>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col">
                        <label class="form-label">Week</label>
                        <input type="number" class="form-control" @bind="_weekNumber" min="1" max="53" />
                    </div>
                    <div class="col">
                        <label class="form-label">Year</label>
                        <input type="number" class="form-control" @bind="_year" min="2020" max="2030" />
                    </div>
                    <div class="col d-flex align-items-end">
                        <button class="btn btn-primary" @onclick="LoadWeeklyHoursAsync">Generate</button>
                    </div>
                </div>

                @if (_isLoadingWeekly)
                {
                    <div class="text-center">
                        <div class="spinner-border spinner-border-sm"></div>
                    </div>
                }
                else if (_weeklySummaries.Any())
                {
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Employee</th>
                                <th>Total</th>
                                <th>Billable</th>
                                <th>%</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var summary in _weeklySummaries)
                            {
                                <tr>
                                    <td>@summary.EmployeeName</td>
                                    <td>@summary.TotalHours.ToString("F1")</td>
                                    <td>@summary.BillableHours.ToString("F1")</td>
                                    <td>
                                        <div class="progress" style="height: 20px;">
                                            <div class="progress-bar @(summary.BillablePercentage >= 70 ? "bg-success" : summary.BillablePercentage >= 50 ? "bg-warning" : "bg-danger")" 
                                                 style="width: @summary.BillablePercentage%;">
                                                @summary.BillablePercentage.ToString("F0")%
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="table-info">
                                <td><strong>Total</strong></td>
                                <td><strong>@_weeklySummaries.Sum(s => s.TotalHours).ToString("F1")</strong></td>
                                <td><strong>@_weeklySummaries.Sum(s => s.BillableHours).ToString("F1")</strong></td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>

                    <h6 class="mt-3">Time Breakdown</h6>
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Employee</th>
                                <th>Vacation</th>
                                <th>Holiday</th>
                                <th>Sick</th>
                                <th>Personal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var summary in _weeklySummaries)
                            {
                                <tr>
                                    <td>@summary.EmployeeName</td>
                                    <td>@(summary.VacationHours > 0 ? summary.VacationHours.ToString("F1") : "-")</td>
                                    <td>@(summary.HolidayHours > 0 ? summary.HolidayHours.ToString("F1") : "-")</td>
                                    <td>@(summary.SickHours > 0 ? summary.SickHours.ToString("F1") : "-")</td>
                                    <td>@(summary.PersonalHours > 0 ? summary.PersonalHours.ToString("F1") : "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">Project Status</h5>
            </div>
            <div class="card-body">
                <button class="btn btn-primary mb-3" @onclick="LoadProjectStatusAsync">Load Active Projects</button>

                @if (_isLoadingProjects)
                {
                    <div class="text-center">
                        <div class="spinner-border spinner-border-sm"></div>
                    </div>
                }
                else if (_projectSummaries.Any())
                {
                    <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                        <table class="table table-sm">
                            <thead class="sticky-top bg-white">
                                <tr>
                                    <th>Project</th>
                                    <th>Customer</th>
                                    <th>Quoted</th>
                                    <th>Billed</th>
                                    <th>Remaining</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var project in _projectSummaries.Where(p => p.RemainingHours > 0))
                                {
                                    var percentUsed = (project.BilledHours / (project.QuotedHours + project.AdditionalHours)) * 100;
                                    <tr>
                                        <td>@project.ProjectCode</td>
                                        <td>@(project.CustomerName ?? project.CustomerId)</td>
                                        <td>@((project.QuotedHours + project.AdditionalHours).ToString("F0"))</td>
                                        <td>@project.BilledHours.ToString("F0")</td>
                                        <td>
                                            <span class="@(project.RemainingHours < 5 ? "text-danger" : "")">
                                                @project.RemainingHours.ToString("F0")
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private bool _isLoadingWeekly;
    private bool _isLoadingProjects;

    private int _weekNumber;
    private int _year;

    private List<WeeklyHoursSummary> _weeklySummaries = new();
    private List<ProjectSummary> _projectSummaries = new();

    protected override void OnInitialized()
    {
        _year = DateTime.Today.Year;
        _weekNumber = GetIso8601WeekOfYear(DateTime.Today);
    }

    private async Task LoadWeeklyHoursAsync()
    {
        _isLoadingWeekly = true;
        var result = await Api.GetWeeklyHoursSummaryAsync(_year, _weekNumber);
        if (result?.Success == true)
        {
            _weeklySummaries = result.Data ?? new();
        }
        _isLoadingWeekly = false;
    }

    private async Task LoadProjectStatusAsync()
    {
        _isLoadingProjects = true;
        var result = await Api.GetProjectSummariesAsync("Active");
        if (result?.Success == true)
        {
            _projectSummaries = result.Data ?? new();
        }
        _isLoadingProjects = false;
    }

    private static int GetIso8601WeekOfYear(DateTime date)
    {
        var day = System.Globalization.CultureInfo.InvariantCulture.Calendar.GetDayOfWeek(date);
        if (day >= DayOfWeek.Monday && day <= DayOfWeek.Wednesday)
        {
            date = date.AddDays(3);
        }
        return System.Globalization.CultureInfo.InvariantCulture.Calendar.GetWeekOfYear(
            date, System.Globalization.CalendarWeekRule.FirstFourDayWeek, DayOfWeek.Monday);
    }
}
