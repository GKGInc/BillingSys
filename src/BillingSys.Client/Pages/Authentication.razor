@page "/authentication"
@page "/authentication/{action}"
@using BillingSys.Client.Services
@inject GoogleAuthService Auth
@inject NavigationManager Navigation

<PageTitle>Sign in — Wrigley Billing</PageTitle>

<div class="container py-5">
    <h3>Sign in</h3>
    <p class="text-muted">Use your tech85.com Google account.</p>
    <button type="button" class="btn btn-primary" @onclick="SignInAsync">Sign in with Google</button>
</div>

@code {
    #region Fields

    [Parameter]
    public string? Action { get; set; }

    #endregion

    #region Event Handlers

    private async Task SignInAsync()
    {
        await Auth.SignInAsync();
        if (await Auth.IsAuthenticatedAsync())
        {
            Navigation.NavigateTo("");
        }
    }

    #endregion
}
