@page "/"
@attribute [Authorize]
@using BillingSys.Client.Services
@using BillingSys.Client.Shared
@using BillingSys.Shared.DTOs
@inherits AppComponentBase
@inject ApiService Api
@inject NavigationManager Navigation

<PageTitle>Dashboard — Wrigley Billing</PageTitle>

<div class="mb-4">
    <h1 class="dashboard-hero-title mb-1">Dashboard</h1>
    <p class="dashboard-hero-sub mb-0">Wrigley billing — overview for week @(_currentWeek), @DateTime.Today.ToString("MMMM yyyy")</p>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-6 col-xl-3">
        <div class="card dashboard-kpi dashboard-kpi-accent" style="--accent: #072960;">
            <div class="card-body">
                <p class="kpi-label mb-1">Current week</p>
                <p class="kpi-value mb-1">W@_currentWeek</p>
                <p class="kpi-meta mb-0">ISO week · @DateTime.Today.ToString("MMMM yyyy")</p>
            </div>
            <div class="card-footer">
                <a href="/timeentry">Enter time</a>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card dashboard-kpi dashboard-kpi-accent" style="--accent: #417ADE;">
            <div class="card-body">
                <p class="kpi-label mb-1">Active projects</p>
                <p class="kpi-value mb-1">@_activeProjectCount</p>
                <p class="kpi-meta mb-0">With remaining hours</p>
            </div>
            <div class="card-footer">
                <a href="/projects">View projects</a>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card dashboard-kpi dashboard-kpi-accent" style="--accent: #FF9D00;">
            <div class="card-body">
                <p class="kpi-label mb-1">This month&apos;s invoices</p>
                <p class="kpi-value mb-1">@_monthlyInvoiceTotal.ToString("C0")</p>
                <p class="kpi-meta mb-0">@_monthlyInvoiceCount invoices</p>
            </div>
            <div class="card-footer">
                <a href="/invoices">View invoices</a>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card dashboard-kpi dashboard-kpi-accent" style="--accent: #B3842B;">
            <div class="card-body">
                <p class="kpi-label mb-1">Quick actions</p>
                <div class="d-grid gap-2 mt-2">
                    <button type="button" class="btn btn-primary btn-sm" @onclick='() => Navigation.NavigateTo("/weeklybilling")'>
                        Weekly billing
                    </button>
                    <button type="button" class="btn btn-outline-primary btn-sm" @onclick='() => Navigation.NavigateTo("/edibilling")'>
                        EDI billing
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-7">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                <h2 class="h5 mb-0">Weekly hours summary</h2>
                <span class="text-muted small">Week @_currentWeek</span>
            </div>
            <div class="card-body">
                @if (_isLoadingWeekly)
                {
                    <div class="text-center py-4">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                }
                else if (_weeklySummaries.Any())
                {
                    <WeeklyHoursChart Items="_weeklySummaries" MaxItems="8" />
                    <hr class="my-4" />
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Employee</th>
                                    <th>Total hrs</th>
                                    <th>Billable</th>
                                    <th>%</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var summary in _weeklySummaries.Take(8))
                                {
                                    <tr>
                                        <td>@summary.EmployeeName</td>
                                        <td>@summary.TotalHours.ToString("F1")</td>
                                        <td>@summary.BillableHours.ToString("F1")</td>
                                        <td>
                                            <span class="badge @(summary.BillablePercentage >= 70 ? "bg-success" : summary.BillablePercentage >= 50 ? "bg-warning" : "bg-danger")">
                                                @summary.BillablePercentage.ToString("F0")%
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <a href="/reports" class="btn btn-outline-primary btn-sm mt-3">View full report</a>
                }
                else
                {
                    <p class="text-muted mb-0">No time entries found for this week.</p>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card h-100">
            <div class="card-header">
                <h2 class="h5 mb-0">Projects needing attention</h2>
            </div>
            <div class="card-body">
                @if (_isLoadingProjects)
                {
                    <div class="text-center py-4">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                }
                else if (_lowHoursProjects.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Project</th>
                                    <th>Customer</th>
                                    <th>Remaining</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var project in _lowHoursProjects.Take(8))
                                {
                                    <tr class="@(project.RemainingHours <= 0 ? "table-danger" : project.RemainingHours < 5 ? "table-warning" : "")">
                                        <td>@project.ProjectCode</td>
                                        <td>@(project.CustomerName ?? project.CustomerId)</td>
                                        <td>@project.RemainingHours.ToString("F1") hrs</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <a href="/projects" class="btn btn-outline-primary btn-sm mt-3">View all projects</a>
                }
                else
                {
                    <p class="text-muted mb-0">All projects have sufficient hours.</p>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private bool _isLoadingWeekly = true;
    private bool _isLoadingProjects = true;

    private int _currentWeek;
    private int _activeProjectCount;
    private int _monthlyInvoiceCount;
    private decimal _monthlyInvoiceTotal;

    private List<WeeklyHoursSummary> _weeklySummaries = new();
    private List<ProjectSummary> _lowHoursProjects = new();

    protected override async Task OnActivatedAsync()
    {
        _currentWeek = GetIso8601WeekOfYear(DateTime.Today);
        await LoadDashboardDataAsync();
    }

    private async Task LoadDashboardDataAsync()
    {
        var weeklyTask = LoadWeeklyDataAsync();
        var projectsTask = LoadProjectsDataAsync();
        var invoicesTask = LoadInvoicesDataAsync();

        await Task.WhenAll(weeklyTask, projectsTask, invoicesTask);
    }

    private async Task LoadWeeklyDataAsync()
    {
        var result = await Api.GetWeeklyHoursSummaryAsync(DateTime.Today.Year, _currentWeek);
        if (result?.Success == true)
        {
            _weeklySummaries = result.Data ?? new();
        }
        _isLoadingWeekly = false;
    }

    private async Task LoadProjectsDataAsync()
    {
        var result = await Api.GetProjectSummariesAsync("Active");
        if (result?.Success == true && result.Data != null)
        {
            _activeProjectCount = result.Data.Count(p => p.RemainingHours > 0);
            _lowHoursProjects = result.Data
                .Where(p => p.RemainingHours < 10)
                .OrderBy(p => p.RemainingHours)
                .ToList();
        }
        _isLoadingProjects = false;
    }

    private async Task LoadInvoicesDataAsync()
    {
        var result = await Api.GetInvoicesAsync(DateTime.Today.Year, DateTime.Today.Month);
        if (result?.Success == true && result.Data != null)
        {
            _monthlyInvoiceCount = result.Data.Count;
            _monthlyInvoiceTotal = result.Data.Sum(i => i.InvoiceAmount);
        }
    }

    private static int GetIso8601WeekOfYear(DateTime date)
    {
        var day = System.Globalization.CultureInfo.InvariantCulture.Calendar.GetDayOfWeek(date);
        if (day >= DayOfWeek.Monday && day <= DayOfWeek.Wednesday)
        {
            date = date.AddDays(3);
        }
        return System.Globalization.CultureInfo.InvariantCulture.Calendar.GetWeekOfYear(
            date, System.Globalization.CalendarWeekRule.FirstFourDayWeek, DayOfWeek.Monday);
    }
}
