@page "/togglreview"
@attribute [Authorize]
@using BillingSys.Client.Services
@using BillingSys.Shared.DTOs
@using BillingSys.Shared.Models
@inject ApiService Api

<PageTitle>Toggl Review — Wrigley Billing</PageTitle>

<h1>Toggl Import & Review</h1>

@* ───── Controls ───── *@
<div class="card mb-3">
    <div class="card-body">
        <div class="row align-items-end">
            <div class="col-md-2">
                <label class="form-label">Start Date</label>
                <input type="date" class="form-control" @bind="_startDate" />
            </div>
            <div class="col-md-2">
                <label class="form-label">End Date</label>
                <input type="date" class="form-control" @bind="_endDate" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Invoice Date</label>
                <input type="date" class="form-control" @bind="_invoiceDate" />
            </div>
            <div class="col-md-2">
                <button class="btn btn-primary w-100" @onclick="PullFromTogglAsync" disabled="@_isPulling">
                    @if (_isPulling)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    Pull Toggl Hours
                </button>
            </div>
            @if (_hasRawEntries)
            {
                <div class="col-md-2">
                    <button class="btn btn-warning w-100" @onclick="SummarizeAndPreviewAsync" disabled="@_isSummarizing">
                        @if (_isSummarizing)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                            <span>Working...</span>
                        }
                        else
                        {
                            <span>Send to Claude</span>
                        }
                    </button>
                </div>
            }
            @if (_hasInvoicePreview)
            {
                <div class="col-md-2">
                    <button class="btn btn-success w-100" @onclick="PostInvoicesAsync" disabled="@_isPosting">
                        @if (_isPosting)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        Post to QBO
                    </button>
                </div>
            }
        </div>

        @if (_pullResult != null)
        {
            <div class="row mt-3">
                <div class="col-md-2">
                    <div class="text-center">
                        <div class="text-muted small">Entries</div>
                        <div class="fw-bold">@_pullResult.TotalEntriesPulled</div>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="text-center">
                        <div class="text-muted small">Blanks Absorbed</div>
                        <div class="fw-bold">@_pullResult.BlankEntriesAbsorbed</div>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="text-center">
                        <div class="text-muted small">Total Hours</div>
                        <div class="fw-bold">@_rawEntries.Sum(e => e.Hours).ToString("F2")</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="text-center">
                        <div class="text-muted small">Batch</div>
                        <div class="fw-bold text-truncate" title="@_pullResult.BatchId">@_pullResult.BatchId</div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@* ───── Side-by-side: Raw Hours (left) + Invoices (right) ───── *@
@if (_hasRawEntries)
{
    <div class="row">
        @* ────── LEFT: Raw Hours ────── *@
        <div class="@(_hasInvoicePreview ? "col-md-6" : "col-md-12")">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Raw Hours from Toggl</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive" style="max-height:70vh;overflow-y:auto;">
                        <table class="table table-sm table-hover mb-0" style="font-size:0.85rem;">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th>Date</th>
                                    <th>Customer</th>
                                    <th>Project</th>
                                    <th>Employee</th>
                                    <th>Description</th>
                                    <th class="text-end">Hours</th>
                                    @if (_rawEntries.Any(e => e.AbsorbedHours > 0))
                                    {
                                        <th class="text-end">+Absorbed</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    string lastDate = "";
                                    string lastCustomer = "";
                                }
                                @foreach (var entry in _rawEntries)
                                {
                                    var dateStr = entry.Date.ToString("MM/dd");
                                    var customerStr = entry.CustomerName ?? entry.ClientName ?? "";
                                    var showDateBreak = dateStr != lastDate;
                                    var showCustomerBreak = customerStr != lastCustomer || showDateBreak;

                                    <tr class="@(showDateBreak && lastDate != "" ? "border-top border-2" : "")">
                                        <td class="@(showDateBreak ? "fw-bold" : "text-muted")">
                                            @(showDateBreak ? dateStr : "")
                                        </td>
                                        <td class="@(showCustomerBreak ? "fw-bold" : "")">
                                            @(showCustomerBreak ? customerStr : "")
                                        </td>
                                        <td><code class="small">@entry.ProjectCode</code></td>
                                        <td>@entry.EmployeeName</td>
                                        <td>@(entry.Description ?? "(blank)")</td>
                                        <td class="text-end">@entry.Hours.ToString("F2")</td>
                                        @if (_rawEntries.Any(e => e.AbsorbedHours > 0))
                                        {
                                            <td class="text-end">
                                                @if (entry.AbsorbedHours > 0)
                                                {
                                                    <span class="badge bg-info">+@entry.AbsorbedHours.ToString("F2")</span>
                                                }
                                            </td>
                                        }
                                    </tr>

                                    lastDate = dateStr;
                                    lastCustomer = customerStr;
                                }
                            </tbody>
                            <tfoot class="table-light">
                                <tr>
                                    <td colspan="5" class="text-end fw-bold">Total</td>
                                    <td class="text-end fw-bold">@_rawEntries.Sum(e => e.Hours).ToString("F2")</td>
                                    @if (_rawEntries.Any(e => e.AbsorbedHours > 0))
                                    {
                                        <td></td>
                                    }
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        @* ────── RIGHT: Invoice Preview (appears after Claude) ────── *@
        @if (_hasInvoicePreview && _invoicePreview != null)
        {
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">Invoices</h5>
                        <span class="badge bg-success fs-6">@_invoicePreview.GrandTotal.ToString("C")</span>
                    </div>
                    <div class="card-body p-0">
                        <div style="max-height:70vh;overflow-y:auto;">
                            @foreach (var customer in _invoicePreview.Customers)
                            {
                                <div class="border-bottom">
                                    <div class="d-flex justify-content-between align-items-center px-3 py-2 bg-light">
                                        <div class="form-check mb-0">
                                            <input class="form-check-input" type="checkbox" @bind="customer.Selected"
                                                id="inv_@customer.CustomerId">
                                            <label class="form-check-label fw-bold" for="inv_@customer.CustomerId">
                                                @customer.CustomerName
                                            </label>
                                        </div>
                                        <span class="fw-bold">@customer.TotalAmount.ToString("C")</span>
                                    </div>
                                    <table class="table table-sm mb-0" style="font-size:0.85rem;">
                                        <thead>
                                            <tr>
                                                <th>Description</th>
                                                <th class="text-end" style="width:60px;">Hrs</th>
                                                <th class="text-end" style="width:70px;">Rate</th>
                                                <th class="text-end" style="width:80px;">Amount</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var line in customer.Lines)
                                            {
                                                <tr>
                                                    <td>
                                                        @if (_editingLineKey == line.BillingGroupKey)
                                                        {
                                                            <div class="input-group input-group-sm">
                                                                <input type="text" class="form-control form-control-sm"
                                                                    @bind="_editingText" />
                                                                <button class="btn btn-sm btn-outline-success"
                                                                    @onclick="() => SaveLineEditAsync(line)">✓</button>
                                                                <button class="btn btn-sm btn-outline-secondary"
                                                                    @onclick="CancelLineEdit">✕</button>
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            <span>@(line.FormattedDescription ?? line.Description)</span>
                                                            <button class="btn btn-link btn-sm p-0 ms-1"
                                                                @onclick="() => StartLineEdit(line)"
                                                                title="Edit description">✎</button>
                                                        }
                                                    </td>
                                                    <td class="text-end">@line.Hours.ToString("F2")</td>
                                                    <td class="text-end">@line.Rate.ToString("C0")</td>
                                                    <td class="text-end fw-bold">@line.Amount.ToString("C")</td>
                                                </tr>
                                            }
                                        </tbody>
                                        <tfoot>
                                            <tr class="table-light">
                                                <td class="text-end fw-bold">Total</td>
                                                <td class="text-end fw-bold">@customer.TotalHours.ToString("F2")</td>
                                                <td></td>
                                                <td class="text-end fw-bold">@customer.TotalAmount.ToString("C")</td>
                                            </tr>
                                        </tfoot>
                                    </table>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@* ───── Posted confirmation ───── *@
@if (_postResult != null)
{
    <div class="alert alert-success mt-3">
        <strong>Posted @_postResult.InvoicesCreated invoices to QBO.</strong>
        <table class="table table-sm mt-2 mb-0">
            <thead>
                <tr>
                    <th>Invoice #</th>
                    <th>Customer</th>
                    <th class="text-end">Amount</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var inv in _postResult.Invoices)
                {
                    <tr>
                        <td>@inv.InvoiceNumber</td>
                        <td>@inv.CustomerName</td>
                        <td class="text-end">@inv.Amount.ToString("C")</td>
                        <td><span class="badge bg-success">@inv.Status</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@* ───── Error ───── *@
@if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
        @_errorMessage
        <button type="button" class="btn-close" @onclick="() => _errorMessage = null"></button>
    </div>
}

@code {
    private bool _isPulling;
    private bool _isSummarizing;
    private bool _isPosting;
    private string? _errorMessage;

    private DateTime _startDate;
    private DateTime _endDate;
    private DateTime _invoiceDate = DateTime.Today;

    private TogglPullResult? _pullResult;
    private TogglInvoicePreview? _invoicePreview;
    private TogglPostInvoicesResult? _postResult;

    private bool _hasRawEntries;
    private bool _hasInvoicePreview;

    private List<RawEntryRow> _rawEntries = new();

    // Inline editing
    private string? _editingLineKey;
    private string _editingText = "";

    protected override void OnInitialized()
    {
        var today = DateTime.Today;
        _startDate = new DateTime(today.Year, today.Month, 1);
        _endDate = today;
    }

    #region Pull

    private async Task PullFromTogglAsync()
    {
        _isPulling = true;
        _errorMessage = null;
        _invoicePreview = null;
        _postResult = null;
        _hasInvoicePreview = false;

        var result = await Api.PullFromTogglAsync(_startDate, _endDate);
        if (result?.Success == true && result.Data != null)
        {
            _pullResult = result.Data;
            BuildRawEntryRows();
            _hasRawEntries = _rawEntries.Any();
        }
        else
        {
            _errorMessage = result?.ErrorMessage ?? "Failed to pull from Toggl";
            _hasRawEntries = false;
        }

        _isPulling = false;
    }

    private void BuildRawEntryRows()
    {
        _rawEntries.Clear();
        if (_pullResult?.Groups == null) return;

        foreach (var group in _pullResult.Groups)
        {
            foreach (var entry in group.Entries)
            {
                _rawEntries.Add(new RawEntryRow
                {
                    Date = entry.Date,
                    CustomerName = group.MappedCustomerName,
                    ClientName = group.TogglClientName,
                    ProjectCode = group.MappedProjectCode ?? group.TogglProjectName ?? "",
                    EmployeeName = entry.EmployeeName,
                    Description = entry.OriginalDescription,
                    Hours = entry.Hours,
                    AbsorbedHours = entry.AbsorbedHours
                });
            }
        }

        _rawEntries = _rawEntries
            .OrderBy(e => e.Date)
            .ThenBy(e => e.CustomerName ?? e.ClientName ?? "")
            .ThenBy(e => e.ProjectCode)
            .ThenBy(e => e.EmployeeName)
            .ToList();
    }

    #endregion

    #region Summarize + Invoice Preview

    private async Task SummarizeAndPreviewAsync()
    {
        if (_pullResult == null) return;

        _isSummarizing = true;
        _errorMessage = null;

        var sumResult = await Api.SummarizeTogglBatchAsync(_pullResult.BatchId);
        if (sumResult?.Success != true)
        {
            _errorMessage = sumResult?.ErrorMessage ?? "Failed to summarize";
            _isSummarizing = false;
            return;
        }

        var previewResult = await Api.GetTogglInvoicePreviewAsync(_pullResult.BatchId, _invoiceDate);
        if (previewResult?.Success == true && previewResult.Data != null)
        {
            _invoicePreview = previewResult.Data;
            _hasInvoicePreview = true;
        }
        else
        {
            _errorMessage = previewResult?.ErrorMessage ?? "Failed to generate invoice preview";
        }

        _isSummarizing = false;
    }

    #endregion

    #region Post Invoices

    private async Task PostInvoicesAsync()
    {
        if (_invoicePreview == null || _pullResult == null) return;

        var selectedIds = _invoicePreview.Customers
            .Where(c => c.Selected)
            .Select(c => c.CustomerId)
            .ToList();

        if (!selectedIds.Any())
        {
            _errorMessage = "Select at least one customer to invoice";
            return;
        }

        _isPosting = true;
        _errorMessage = null;

        var result = await Api.PostTogglInvoicesAsync(_pullResult.BatchId, _invoiceDate, selectedIds);
        if (result?.Success == true)
        {
            _postResult = result.Data;
        }
        else
        {
            _errorMessage = result?.ErrorMessage ?? "Failed to post invoices";
        }

        _isPosting = false;
    }

    #endregion

    #region Inline Editing

    private void StartLineEdit(TogglInvoiceLine line)
    {
        _editingLineKey = line.BillingGroupKey;
        _editingText = line.FormattedDescription ?? line.Description;
    }

    private void CancelLineEdit()
    {
        _editingLineKey = null;
        _editingText = "";
    }

    private async Task SaveLineEditAsync(TogglInvoiceLine line)
    {
        if (string.IsNullOrWhiteSpace(_editingText)) return;

        if (_pullResult != null)
        {
            foreach (var entryId in line.EntryIds)
            {
                await Api.EditTogglSummaryAsync(_pullResult.BatchId, entryId, _editingText);
            }
        }

        line.FormattedDescription = _editingText;
        _editingLineKey = null;
        _editingText = "";
    }

    #endregion

    #region View Model

    private class RawEntryRow
    {
        public DateTime Date { get; set; }
        public string? CustomerName { get; set; }
        public string? ClientName { get; set; }
        public string ProjectCode { get; set; } = "";
        public string EmployeeName { get; set; } = "";
        public string? Description { get; set; }
        public decimal Hours { get; set; }
        public decimal AbsorbedHours { get; set; }
    }

    #endregion
}
